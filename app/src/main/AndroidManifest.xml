<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- 允许应用使用PowerManager.WakeLock，防止CPU休眠或屏幕变暗/关闭 -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- 允许应用在后台时启动一个新的Activity -->
    <uses-permission android:name="android.permission.START_ACTIVITIES_FROM_BACKGROUND"
        tools:ignore="ProtectedPermissions" />
    <!-- 允许应用重新排序当前运行的任务 -->
    <uses-permission android:name="android.permission.REORDER_TASKS" />
    <!-- 声明应用有能力使用前台服务 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- 用于声明前台服务属于“特殊用途”类型 -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- 允许应用写入/读取外部存储 -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"/>
<!--    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />-->
    <!-- 允许应用收集其他应用的使用情况统计信息 -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.WRITE_SETTINGS"
        tools:ignore="ProtectedPermissions" />

    <!-- 充电保护相关权限 -->
    <uses-permission android:name="android.permission.DEVICE_POWER" tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.SHUTDOWN" tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.BATTERY_STATS" tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RetailDemo"
        tools:targetApi="31">
        <activity
            android:name=".DemoPlayer"
            android:exported="true"
            android:immersive="true"
            android:excludeFromRecents="true"
            android:screenOrientation="nosensor"
            android:icon="@mipmap/demoplayer_icon"
            android:theme="@android:style/Theme.Wallpaper.NoTitleBar.Fullscreen">
            <intent-filter android:priority="6">
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".HelloActivity"
            android:exported="false" />

        <service
            android:name=".UserActivityMonitorService"
            android:foregroundServiceType="specialUse"
            android:exported="false" />

        <!-- This isn't a real receiver, it's only used as a marker interface. -->
        <receiver android:name=".DemoModeCustomizationReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.android.launcher3.action.PARTNER_CUSTOMIZATION" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".DialerCodeReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.provider.Telephony.SECRET_CODE" />
                <category android:name="android.intent.category.DEFAULT" />
                <!-- 启动演示应用暗码 -->
                <data android:scheme="android_secret_code" android:host="9876" />
                <!-- 卸载演示应用暗码 -->
                <data android:scheme="android_secret_code" android:host="5010" />
            </intent-filter>
        </receiver>
    </application>

</manifest>